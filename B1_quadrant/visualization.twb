  <worksheets>
    <worksheet name='Sheet 2'>
      <table>
        <view>
          <datasources>
            <datasource caption='Sheet1 (movies_visuals)' name='federated.1431yjj0bc0z161dyz9je15bgnzl' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Select Aggregation Type' datatype='string' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;Average&quot;'>
              <calculation class='tableau' formula='&quot;Average&quot;' />
            </column>
            <column caption='Select Parameter' datatype='string' name='[Parameter 3]' param-domain-type='list' role='measure' type='nominal' value='&quot;Performance&quot;'>
              <calculation class='tableau' formula='&quot;Performance&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1431yjj0bc0z161dyz9je15bgnzl'>
            <column caption='Dynamic_movie_ratings' datatype='real' name='[Calculation_0277406166302720]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;  WHEN &quot;Average&quot; THEN AVG([averageRating])&#13;&#10;  WHEN &quot;Total&quot; THEN SUM([averageRating])&#13;&#10;  WHEN &quot;Minimum&quot; THEN MIN([averageRating])&#13;&#10;  WHEN &quot;Maximum&quot; THEN MAX([averageRating])&#13;&#10;END' />
            </column>
            <column caption='Dynamic_movie_numvotes' datatype='real' name='[Calculation_0277406167007233]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;  WHEN &quot;Average&quot; THEN AVG([numVotes])&#13;&#10;  WHEN &quot;Total&quot; THEN SUM([numVotes])&#13;&#10;  WHEN &quot;Minimum&quot; THEN MIN([numVotes])&#13;&#10;  WHEN &quot;Maximum&quot; THEN MAX([numVotes])&#13;&#10;END' />
            </column>
            <column caption='Dynamic_category' datatype='string' name='[Calculation_0277406183862286]' role='dimension' type='nominal'>
